# ============================================================
# ENVIRONMENT VARIABLES — Ashar Disability Care
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to version control
# ============================================================

# Sanity CMS — get these from sanity.io/manage → your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id-here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_READ_TOKEN=your-read-token-here

# Site URL — used for canonical URLs and sitemap
NEXT_PUBLIC_SITE_URL=https://ashardisabilitycare.com.au

# ISR Webhook — Sanity revalidation (generate any random secret string)
# Add this same value in sanity.io/manage → API → Webhooks → Secret
SANITY_WEBHOOK_SECRET=your-webhook-secret-here
